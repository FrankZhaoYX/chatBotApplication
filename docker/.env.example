# Copy to docker/.env and uncomment to override defaults.

# --- Ollama location ---
# Default: use the ollama container on the internal Docker network.
# LAN override: point at Ollama running on another machine (e.g. a desktop).
#OLLAMA_URL=http://192.168.50.33:11434

# When using a LAN Ollama you can remove the `ollama` service from
# docker-compose.yml and its depends_on/healthcheck references.
